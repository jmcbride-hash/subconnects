# SubConnects — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env*

# ─────────────────────────────────────────────────────────────
# DATABASE — Supabase Postgres connection (used by Drizzle)
# Get the connection string from Supabase Project Settings → Database → Connection String → URI (Transaction mode for serverless)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Direct (non-pooled) connection — used by drizzle-kit for migrations
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────
# SUPABASE AUTH — public + service keys
# Get from Supabase Project Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret-key>"

# ─────────────────────────────────────────────────────────────
# DWOLLA — ACH subscription billing (Stage 1+)
# Sandbox first; switch to production once entity + bank are KYC'd
# ─────────────────────────────────────────────────────────────
DWOLLA_ENV="sandbox" # or "production"
DWOLLA_KEY="<dwolla-app-key>"
DWOLLA_SECRET="<dwolla-app-secret>"
DWOLLA_WEBHOOK_SECRET="<dwolla-webhook-signing-secret>"
SUBCONNECTS_MASTER_FUNDING_SOURCE_ID="<our-business-bank-funding-source-id>"

# ─────────────────────────────────────────────────────────────
# AWS S3 — file uploads (COIs, licenses, message attachments, logos)
# ─────────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_S3_BUCKET="subconnects-uploads"
AWS_ACCESS_KEY_ID="<iam-user-access-key>"
AWS_SECRET_ACCESS_KEY="<iam-user-secret>"

# ─────────────────────────────────────────────────────────────
# RESEND — transactional email
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY="<resend-api-key>"
RESEND_FROM_EMAIL="hello@subconnects.com"

# ─────────────────────────────────────────────────────────────
# MAPBOX — geocoding (address → lat/lng), service-area maps
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN="pk.<mapbox-public-token>"
MAPBOX_SECRET_TOKEN="sk.<mapbox-secret-token>"

# ─────────────────────────────────────────────────────────────
# OBSERVABILITY
# ─────────────────────────────────────────────────────────────
SENTRY_DSN="https://<key>@<org>.ingest.sentry.io/<project>"
NEXT_PUBLIC_POSTHOG_KEY="phc_<key>"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ─────────────────────────────────────────────────────────────
# TALLY — pre-launch waitlist forms
# Create the forms in Tally → Share → Embed → grab the form ID
# Form ID looks like "wMpEYO" or "wabc1234"
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_TALLY_CONTRACTOR_FORM_ID=""
NEXT_PUBLIC_TALLY_CREW_FORM_ID=""

# ─────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
